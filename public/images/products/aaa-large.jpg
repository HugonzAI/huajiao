<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400">
  <defs>
    <radialGradient id="bg1" cx="50%" cy="40%" r="65%">
      <stop offset="0%" stop-color="#fef7e0"/>
      <stop offset="100%" stop-color="#f0d48a"/>
    </radialGradient>
    <radialGradient id="maw1" cx="40%" cy="38%" r="60%">
      <stop offset="0%" stop-color="#fbe9a0"/>
      <stop offset="55%" stop-color="#e8c55a"/>
      <stop offset="100%" stop-color="#b87820"/>
    </radialGradient>
    <filter id="sh1" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="2" dy="8" stdDeviation="10" flood-color="#a87820" flood-opacity="0.35"/>
    </filter>
  </defs>
  <rect width="400" height="400" fill="url(#bg1)"/>
  <ellipse cx="200" cy="390" rx="270" ry="70" fill="#e8c55a" opacity="0.18"/>
  <!-- Main maw body -->
  <g filter="url(#sh1)" transform="translate(200,188)">
    <path d="M0,-118 C58,-108 92,-62 88,12 C84,78 48,118 0,120 C-48,118 -84,78 -88,12 C-92,-62 -58,-108 0,-118Z"
          fill="url(#maw1)"/>
    <path d="M0,-88 C33,-80 52,-48 50,8 C48,56 28,84 0,86" fill="none" stroke="#fdf8ee" stroke-width="1.8" opacity="0.45" stroke-dasharray="5 3"/>
    <path d="M0,-55 C20,-50 32,-28 30,8 C28,38 16,56 0,58" fill="none" stroke="#fdf8ee" stroke-width="1.2" opacity="0.35" stroke-dasharray="3 3"/>
    <ellipse cx="-20" cy="-58" rx="20" ry="34" fill="white" opacity="0.18" transform="rotate(-18,-20,-58)"/>
    <ellipse cx="-24" cy="-50" rx="7" ry="14" fill="white" opacity="0.28" transform="rotate(-18,-24,-50)"/>
    <path d="M-42,-32 Q-12,2 -38,48" stroke="#a87820" stroke-width="1.2" opacity="0.28" fill="none" stroke-linecap="round"/>
    <path d="M22,-52 Q48,-8 32,52" stroke="#a87820" stroke-width="1.2" opacity="0.28" fill="none" stroke-linecap="round"/>
  </g>
  <!-- Grade badge -->
  <rect x="20" y="20" width="72" height="30" rx="7" fill="#c9972a"/>
  <text x="56" y="40" text-anchor="middle" font-family="Georgia,serif" font-size="15" font-weight="700" fill="white" letter-spacing="1">AAA</text>
  <!-- Bottom info band -->
  <rect x="0" y="328" width="400" height="72" fill="#1a1208" opacity="0.84"/>
  <text x="200" y="355" text-anchor="middle" font-family="Georgia,serif" font-size="15" font-weight="700" fill="#f0d48a">特级菲律宾花胶（大）</text>
  <text x="200" y="374" text-anchor="middle" font-family="Arial,sans-serif" font-size="11" fill="#d9a93e">AAA · Philippines · 500g</text>
  <text x="200" y="391" text-anchor="middle" font-family="Georgia,serif" font-size="12" font-weight="700" fill="#c9972a">HKD 2,980</text>
  <path d="M356,0 L400,0 L400,44" fill="none" stroke="#c9972a" stroke-width="1.5" opacity="0.5"/>
  <path d="M0,356 L0,400 L44,400" fill="none" stroke="#c9972a" stroke-width="1.5" opacity="0.5"/>
</svg>
