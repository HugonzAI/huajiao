<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400">
  <defs>
    <linearGradient id="boxGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#2a1a08"/>
      <stop offset="100%" stop-color="#1a0e04"/>
    </linearGradient>
    <radialGradient id="lidGrad" cx="50%" cy="30%" r="60%">
      <stop offset="0%" stop-color="#c9972a"/>
      <stop offset="100%" stop-color="#8a6318"/>
    </radialGradient>
    <radialGradient id="mawG" cx="40%" cy="38%" r="60%">
      <stop offset="0%" stop-color="#fbe9a0"/>
      <stop offset="55%" stop-color="#e8c55a"/>
      <stop offset="100%" stop-color="#b87820"/>
    </radialGradient>
    <filter id="shG" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="3" dy="10" stdDeviation="12" flood-color="#000" flood-opacity="0.5"/>
    </filter>
  </defs>
  <!-- Rich dark background -->
  <rect width="400" height="400" fill="#1e1408"/>
  <!-- Gold ornament pattern -->
  <circle cx="50" cy="50" r="30" fill="none" stroke="#c9972a" stroke-width="0.5" opacity="0.2"/>
  <circle cx="350" cy="50" r="30" fill="none" stroke="#c9972a" stroke-width="0.5" opacity="0.2"/>
  <circle cx="50" cy="350" r="30" fill="none" stroke="#c9972a" stroke-width="0.5" opacity="0.2"/>
  <circle cx="350" cy="350" r="30" fill="none" stroke="#c9972a" stroke-width="0.5" opacity="0.2"/>
  <!-- Gift box -->
  <g filter="url(#shG)">
    <!-- Box body -->
    <rect x="95" y="200" width="210" height="130" rx="4" fill="url(#boxGrad)"/>
    <!-- Box border gold -->
    <rect x="95" y="200" width="210" height="130" rx="4" fill="none" stroke="#c9972a" stroke-width="1.5"/>
    <!-- Gold band horizontal -->
    <rect x="95" y="255" width="210" height="18" fill="#c9972a" opacity="0.7"/>
    <!-- Box lid -->
    <rect x="88" y="178" width="224" height="30" rx="4" fill="url(#lidGrad)"/>
    <rect x="88" y="178" width="224" height="30" rx="4" fill="none" stroke="#e8c55a" stroke-width="1"/>
    <!-- Lid text -->
    <text x="200" y="198" text-anchor="middle" font-family="Georgia,serif" font-size="11" fill="#fdf8ee" letter-spacing="3">BETTER HEALTH</text>
  </g>
  <!-- Ribbon bow -->
  <g transform="translate(200,178)">
    <!-- Left ribbon loop -->
    <path d="M0,0 C-35,-30 -55,-10 -30,5 C-15,12 0,0 0,0Z" fill="#c9972a" opacity="0.9"/>
    <path d="M0,0 C-35,-30 -55,-10 -30,5 C-15,12 0,0 0,0Z" fill="none" stroke="#e8c55a" stroke-width="0.8"/>
    <!-- Right ribbon loop -->
    <path d="M0,0 C35,-30 55,-10 30,5 C15,12 0,0 0,0Z" fill="#c9972a" opacity="0.9"/>
    <path d="M0,0 C35,-30 55,-10 30,5 C15,12 0,0 0,0Z" fill="none" stroke="#e8c55a" stroke-width="0.8"/>
    <!-- Bow knot -->
    <circle cx="0" cy="0" r="7" fill="#e8c55a"/>
    <circle cx="0" cy="0" r="4" fill="#c9972a"/>
  </g>
  <!-- Fish maw peeking from box -->
  <g transform="translate(200,245) scale(0.6)">
    <path d="M0,-70 C32,-64 50,-36 48,8 C46,42 24,66 0,68 C-24,66 -46,42 -48,8 C-50,-36 -32,-64 0,-70Z" fill="url(#mawG)"/>
    <ellipse cx="-10" cy="-30" rx="10" ry="18" fill="white" opacity="0.2" transform="rotate(-15,-10,-30)"/>
  </g>
  <!-- Grade badge -->
  <rect x="20" y="20" width="72" height="30" rx="7" fill="#c9972a"/>
  <text x="56" y="40" text-anchor="middle" font-family="Georgia,serif" font-size="15" font-weight="700" fill="white" letter-spacing="1">AAA</text>
  <!-- Gift icon -->
  <rect x="310" y="20" width="70" height="30" rx="7" fill="none" stroke="#c9972a" stroke-width="1.5"/>
  <text x="345" y="40" text-anchor="middle" font-family="Arial,sans-serif" font-size="11" fill="#c9972a">礼盒</text>
  <!-- Info band -->
  <rect x="0" y="342" width="400" height="58" fill="#0a0804" opacity="0.9"/>
  <text x="200" y="364" text-anchor="middle" font-family="Georgia,serif" font-size="14" font-weight="700" fill="#f0d48a">经典礼盒装花胶</text>
  <text x="200" y="382" text-anchor="middle" font-family="Arial,sans-serif" font-size="11" fill="#d9a93e">Gift Set · AAA Philippines · 300g</text>
  <text x="200" y="396" text-anchor="middle" font-family="Georgia,serif" font-size="11" font-weight="700" fill="#c9972a">HKD 2,200</text>
</svg>
