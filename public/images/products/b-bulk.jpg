    </g>
    <g transform="translate(230,145) rotate(15)">
      <path d="M0,-50 C22,-46 35,-26 33,7 C31,33 17,49 0,50 C-17,49 -31,33 -33,7 C-35,-26 -22,-46 0,-50Z" fill="url(#maw6)"/>
      <ellipse cx="7" cy="-22" rx="6" ry="11" fill="white" opacity="0.18" transform="rotate(12,7,-22)"/>
    </g>
    <g transform="translate(175,225) rotate(-8)">
      <path d="M0,-52 C23,-48 36,-27 34,8 C32,34 17,51 0,52 C-17,51 -32,34 -34,8 C-36,-27 -23,-48 0,-52Z" fill="url(#maw6)"/>
      <ellipse cx="-7" cy="-22" rx="6" ry="12" fill="white" opacity="0.18" transform="rotate(-10,-7,-22)"/>
    </g>
    <g transform="translate(265,215) rotate(22)">
      <path d="M0,-48 C21,-44 33,-24 31,7 C29,32 16,47 0,48 C-16,47 -29,32 -31,7 C-33,-24 -21,-44 0,-48Z" fill="url(#maw6)"/>
    </g>
    <g transform="translate(120,225) rotate(5)">
      <path d="M0,-45 C20,-41 31,-23 29,7 C27,30 15,44 0,45 C-15,44 -27,30 -29,7 C-31,-23 -20,-41 0,-45Z" fill="url(#maw6)"/>
    </g>
  </g>
  <!-- Bulk label -->
  <rect x="20" y="20" width="60" height="30" rx="7" fill="#c89030"/>
  <text x="50" y="40" text-anchor="middle" font-family="Georgia,serif" font-size="16" font-weight="700" fill="white" letter-spacing="1">B</text>
  <rect x="0" y="328" width="400" height="72" fill="#1a1208" opacity="0.84"/>
  <text x="200" y="355" text-anchor="middle" font-family="Georgia,serif" font-size="15" font-weight="700" fill="#f0d48a">二级南非花胶大装</text>
  <text x="200" y="374" text-anchor="middle" font-family="Arial,sans-serif" font-size="11" fill="#d9a93e">B Grade · South Africa · 1000g</text>
  <text x="200" y="391" text-anchor="middle" font-family="Georgia,serif" font-size="12" font-weight="700" fill="#c9972a">HKD 1,480</text>
