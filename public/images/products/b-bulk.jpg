<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400">
  <defs>
    <radialGradient id="bg6" cx="50%" cy="40%" r="65%">
      <stop offset="0%" stop-color="#fdf2cc"/>
      <stop offset="100%" stop-color="#e0b84a"/>
    </radialGradient>
    <radialGradient id="maw6" cx="40%" cy="38%" r="60%">
      <stop offset="0%" stop-color="#f0d888"/>
      <stop offset="55%" stop-color="#c89030"/>
      <stop offset="100%" stop-color="#8a6018"/>
    </radialGradient>
    <filter id="sh6" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="1" dy="5" stdDeviation="6" flood-color="#6a4810" flood-opacity="0.28"/>
    </filter>
  </defs>
  <rect width="400" height="400" fill="url(#bg6)"/>
  <!-- Multiple small pieces -->
  <g filter="url(#sh6)">
    <g transform="translate(140,160) rotate(-20)">
      <path d="M0,-55 C24,-50 38,-28 36,8 C34,36 18,54 0,55 C-18,54 -34,36 -36,8 C-38,-28 -24,-50 0,-55Z" fill="url(#maw6)"/>
