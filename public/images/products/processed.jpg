<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400">
  <defs>
    <radialGradient id="bg8" cx="50%" cy="40%" r="65%">
      <stop offset="0%" stop-color="#e8f4ee"/>
      <stop offset="100%" stop-color="#c8e8d8"/>
    </radialGradient>
    <radialGradient id="maw8" cx="40%" cy="38%" r="60%">
      <stop offset="0%" stop-color="#fbe9a0"/>
      <stop offset="55%" stop-color="#e8c55a"/>
      <stop offset="100%" stop-color="#b87820"/>
    </radialGradient>
    <filter id="sh8" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="2" dy="8" stdDeviation="8" flood-color="#4a7860" flood-opacity="0.3"/>
    </filter>
  </defs>
  <rect width="400" height="400" fill="url(#bg8)"/>
  <!-- Bowl -->
  <g filter="url(#sh8)">
    <!-- Bowl body -->
    <ellipse cx="200" cy="250" rx="130" ry="30" fill="#f0e8d0"/>
    <path d="M70,230 Q80,290 200,300 Q320,290 330,230 Z" fill="#fdf5e8"/>
    <path d="M70,230 Q80,290 200,300 Q320,290 330,230 Z" fill="none" stroke="#d9a93e" stroke-width="1.5"/>
    <!-- Bowl rim -->
    <ellipse cx="200" cy="230" rx="130" ry="22" fill="#fdf5e8" stroke="#d9a93e" stroke-width="1.5"/>
    <!-- Soup liquid -->
    <ellipse cx="200" cy="232" rx="120" ry="16" fill="#f5e0a0" opacity="0.8"/>
    <!-- Steam wisps -->
    <path d="M155,220 Q150,205 158,195 Q165,185 160,175" fill="none" stroke="#c9972a" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
    <path d="M200,218 Q195,202 203,192 Q210,182 205,172" fill="none" stroke="#c9972a" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
    <path d="M245,220 Q240,204 248,194 Q256,184 250,174" fill="none" stroke="#c9972a" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
  </g>
  <!-- Fish maw pieces floating in soup -->
  <g transform="translate(185,240) rotate(-10) scale(0.55)">
    <path d="M0,-60 C26,-54 42,-32 40,7 C38,38 20,58 0,60 C-20,58 -38,38 -40,7 C-42,-32 -26,-54 0,-60Z" fill="url(#maw8)"/>
    <ellipse cx="-8" cy="-26" rx="8" ry="14" fill="white" opacity="0.2" transform="rotate(-12,-8,-26)"/>
  </g>
  <g transform="translate(222,238) rotate(15) scale(0.48)">
    <path d="M0,-56 C24,-50 38,-30 36,7 C34,36 18,54 0,56 C-18,54 -34,36 -36,7 C-38,-30 -24,-50 0,-56Z" fill="url(#maw8)"/>
    <ellipse cx="7" cy="-22" rx="6" ry="12" fill="white" opacity="0.2" transform="rotate(12,7,-22)"/>
  </g>
  <!-- Ready badge -->
  <rect x="20" y="20" width="88" height="30" rx="7" fill="#4a9060"/>
  <text x="64" y="40" text-anchor="middle" font-family="Arial,sans-serif" font-size="12" font-weight="700" fill="white" letter-spacing="0.5">即食 Ready</text>
  <!-- Info band -->
  <rect x="0" y="328" width="400" height="72" fill="#1a1208" opacity="0.84"/>
  <text x="200" y="355" text-anchor="middle" font-family="Georgia,serif" font-size="15" font-weight="700" fill="#f0d48a">即食花胶（已发制）</text>
  <text x="200" y="374" text-anchor="middle" font-family="Arial,sans-serif" font-size="11" fill="#d9a93e">Ready-to-Cook · Indonesia · 200g</text>
  <text x="200" y="391" text-anchor="middle" font-family="Georgia,serif" font-size="12" font-weight="700" fill="#c9972a">HKD 680</text>
</svg>
