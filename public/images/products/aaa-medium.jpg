<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400">
  <defs>
    <radialGradient id="bg2" cx="50%" cy="40%" r="65%">
      <stop offset="0%" stop-color="#fef7e0"/>
      <stop offset="100%" stop-color="#f0d48a"/>
    </radialGradient>
    <radialGradient id="maw2" cx="40%" cy="38%" r="60%">
      <stop offset="0%" stop-color="#fbe9a0"/>
      <stop offset="55%" stop-color="#e8c55a"/>
      <stop offset="100%" stop-color="#b87820"/>
    </radialGradient>
    <filter id="sh2" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="2" dy="6" stdDeviation="8" flood-color="#a87820" flood-opacity="0.3"/>
    </filter>
  </defs>
  <rect width="400" height="400" fill="url(#bg2)"/>
  <!-- Two medium pieces arranged -->
