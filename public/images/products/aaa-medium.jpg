    <path d="M0,-82 C38,-74 62,-42 58,10 C54,54 30,82 0,84 C-30,82 -54,54 -58,10 C-62,-42 -38,-74 0,-82Z" fill="url(#maw2)"/>
    <ellipse cx="12" cy="-40" rx="12" ry="22" fill="white" opacity="0.2" transform="rotate(15,12,-40)"/>
    <path d="M28,-20 Q8,4 24,36" stroke="#a87820" stroke-width="1" opacity="0.25" fill="none"/>
  </g>
